<%- include('partials/header', { title: 'Cursos' }) %>

<section class="hero">
  <h1>Explora los cursos oficiales de la Asociación Scout de Venezuela</h1>
  <p>Avanza por secciones diseñadas para que cada curso sea claro, seguro y progresivo. Completa tus módulos y obtén certificación sin complicaciones.</p>
  <div class="hero-actions">
    <a class="button" href="/login">Entrar a mi panel</a>
  </div>
</section>

<section class="stats-grid">
  <article class="metric-card">
    <h3>Cursos disponibles</h3>
    <div class="metric-value"><%= courses.length %></div>
    <p>Encuentra contenido actualizado para tu formación scout.</p>
  </article>
</section>

<section class="courses-grid">
  <% if (courses.length === 0) { %>
    <article class="course-card">
      <p>No hay cursos publicados todavía. Un administrador puede crear el primero.</p>
    </article>
  <% } %>
  <% courses.forEach(course => { %>
    <article class="course-card">
      <h2><a href="/courses/<%= course.id %>"><%= course.title %></a></h2>
      <p><%= course.description %></p>
      <div class="course-progress">
        <small>Más información disponible en el curso</small>
        <a class="button-secondary" href="/courses/<%= course.id %>">Ver curso</a>
      </div>
    </article>
  <% }) %>
</section>

<%- include('partials/footer') %>
