<%- include('partials/header', { title: 'Registrarse' }) %>
<section class="auth-page">
  <div class="auth-aside">
    <h1>Únete a la comunidad</h1>
    <p>Registra tu cuenta para acceder a cursos oficiales, avanzar por secciones y obtener tus certificados digitales.</p>
  </div>

  <div class="auth-panel form-card">
    <h1>Crear cuenta</h1>
    <form action="/register" method="POST">
      <label>Nombre completo</label>
      <input name="name" type="text" required placeholder="Tu nombre completo" />
      <label>Correo electrónico</label>
      <input name="email" type="email" required placeholder="tu@email.com" />
      <label>Contraseña</label>
      <input name="password" type="password" required placeholder="Crea una contraseña segura" />
      <button type="submit" class="button">Registrarse</button>
    </form>
    <p>¿Ya tienes cuenta? <a href="/login">Inicia sesión</a></p>
  </div>
</section>
<%- include('partials/footer') %>
