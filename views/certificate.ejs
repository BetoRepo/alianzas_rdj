<%- include('partials/header', { title: 'Certificado' }) %>
<section class="certificate-page">
  <div class="certificate-card">
    <div class="certificate-diptych">
      <div class="certificate-title">FORMACIÓN DEL JOVEN Y ADULTO SCOUT</div>
      <div class="certificate-subtitle">La Asociación de Scouts de Venezuela certifica que</div>
      <div class="certificate-name"><%= user.name %></div>
      <div class="certificate-description">ha aprobado el curso de</div>
      <div class="certificate-course"><%= course.title %></div>
      <div class="certificate-note">Certificando que los requisitos de la Asociación de Scouts de Venezuela en su Sistema de Formación Scout se han completado.</div>
      <div class="certificate-footer">
        <div>
          <div class="signature-line"></div>
          <div class="signature-label">Fulanito</div>
        </div>
        <div>
          <div class="signature-line"></div>
          <div class="signature-label">Fulanito</div>
        </div>
      </div>
      <div class="certificate-date">Fecha: <%= new Date(completedAt).toLocaleDateString('es-VE') %></div>
    </div>
    <button class="button" onclick="window.print()">Descargar / Imprimir certificado</button>
  </div>
</section>
<%- include('partials/footer') %>
