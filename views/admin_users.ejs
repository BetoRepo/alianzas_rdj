<%- include('partials/header', { title: 'Administrar Usuarios' }) %>
<section>
  <h1>Administrar Usuarios</h1>
  <p>Gestiona los usuarios del sistema: crea nuevos usuarios o elimina los existentes.</p>
</section>

<section class="form-card">
  <h2>Crear nuevo usuario</h2>
  <form action="/admin/users/create" method="POST">
    <label>Nombre</label>
    <input name="name" type="text" required />
    <label>Correo electrónico</label>
    <input name="email" type="email" required />
    <label>Contraseña</label>
    <input name="password" type="password" required />
    <label>
      <input name="is_admin" type="checkbox" /> Es administrador
    </label>
    <button type="submit">Crear usuario</button>
  </form>
</section>

<section class="form-card">
  <h2>Lista de usuarios</h2>
  <table>
    <thead>
      <tr>
        <th>Nombre</th>
        <th>Correo</th>
        <th>Rol</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(user => { %>
        <tr>
          <td><%= user.name %></td>
          <td><%= user.email %></td>
          <td><%= user.is_admin ? 'Administrador' : 'Usuario' %></td>
          <td>
            <form action="/admin/users/<%= user.id %>/delete" method="POST" style="display:inline;">
              <button type="submit" onclick="return confirm('¿Estás seguro de eliminar este usuario?')">Eliminar</button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</section>

<%- include('partials/footer') %>